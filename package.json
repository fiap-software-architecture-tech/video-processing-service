{
    "name": "video-processing-service",
    "version": "1.0.0",
    "type": "module",
    "description": "Hackaton do curso SOAT FIAP",
    "main": "src/index.ts",
    "author": "Grupo 277",
    "scripts": {
        "build": "npm run build:clean && tsup",
        "build:clean": "rimraf dist",
        "dev": "npm run build && serverless invoke local --function processVideo --path event.json",
        "dev:deploy": "serverless deploy --stage local",
        "start": "npm run build && node dist/index.js",
        "lint": "tsc && eslint ./src/**/*.ts",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage --reporter=verbose",
        "prisma:generate": "prisma generate",
        "prisma:seed": "tsx prisma/seed.ts",
        "prisma:migrate": "prisma migrate dev",
        "prisma:reset": "prisma migrate reset",
        "prisma:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "prod": "node dist/index.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fiap-software-architecture-tech/video-processing-service.git"
    },
    "keywords": [],
    "license": "ISC",
    "homepage": "https://github.com/fiap-software-architecture-tech/video-processing-service#readme",
    "engineStrict": true,
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "dotenv": "^16.5.0",
        "http-status-codes": "^2.3.0",
        "inversify": "^7.6.1",
        "pino": "^10.1.0",
        "pino-pretty": "^13.1.3",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.1000.0",
        "@aws-sdk/client-sqs": "^3.1000.0",
        "@eslint/js": "^9.26.0",
        "@types/aws-lambda": "^8.10.161",
        "@types/node": "^22.15.18",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "@vitest/coverage-v8": "4.0.16",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-import-resolver-typescript": "^4.3.4",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.4.0",
        "globals": "^16.1.0",
        "prettier": "^3.5.3",
        "rimraf": "^6.0.1",
        "serverless": "^4.33.0",
        "serverless-localstack": "^1.3.1",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "tsup": "^8.5.1",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1",
        "vitest": "^4.0.16"
    }
}
